---
import { env } from 'cloudflare:workers';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ResetPasswordForm } from '@/components/auth/ResetPasswordForm';
import { ThemeToggle } from '@/components/layout/ThemeToggle';
import { getBranding } from '@/lib/branding';

// Reachable while carrying Supabase's own recovery-session URL params — must
// not redirect based on Astro.locals.user here (a recovery link click does
// establish a session), unlike /login's "already signed in" redirect.
const branding = await getBranding(Astro.locals.supabase);
---

<BaseLayout title="Restablecer contraseña" siteName={branding.name} faviconUrl={branding.faviconUrl}>
  <div class="bg-background relative min-h-screen overflow-hidden">
    <div
      class="bg-accent-lilac pointer-events-none absolute -top-24 -left-24 size-96 rounded-full opacity-30 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div
      class="bg-accent-green pointer-events-none absolute -right-24 -bottom-24 size-96 rounded-full opacity-30 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div class="absolute top-4 right-4 z-10">
      <ThemeToggle client:load />
    </div>
    <div class="relative flex min-h-screen items-center justify-center p-4">
      <ResetPasswordForm
        client:load
        supabaseUrl={env.SUPABASE_URL}
        supabaseAnonKey={env.SUPABASE_ANON_KEY}
        name={branding.name}
        logoUrl={branding.logoUrl}
      />
    </div>
  </div>
</BaseLayout>
