---
import { env } from 'cloudflare:workers';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ForgotPasswordForm } from '@/components/auth/ForgotPasswordForm';
import { ThemeToggle } from '@/components/layout/ThemeToggle';
import { getBranding } from '@/lib/branding';

const branding = await getBranding(Astro.locals.supabase);
---

<BaseLayout title="Recuperar contraseña" siteName={branding.name} faviconUrl={branding.faviconUrl}>
  <div class="bg-background relative min-h-screen overflow-hidden">
    <div
      class="bg-accent-pink pointer-events-none absolute -top-24 -left-24 size-96 rounded-full opacity-30 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div
      class="bg-accent-blue pointer-events-none absolute -right-24 -bottom-24 size-96 rounded-full opacity-30 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div class="absolute top-4 right-4">
      <ThemeToggle client:load />
    </div>
    <div class="relative flex min-h-screen items-center justify-center p-4">
      <ForgotPasswordForm
        client:load
        turnstileSiteKey={env.PUBLIC_TURNSTILE_SITE_KEY}
        name={branding.name}
        logoUrl={branding.logoUrl}
      />
    </div>
  </div>
</BaseLayout>
