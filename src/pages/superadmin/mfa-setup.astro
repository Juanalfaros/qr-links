---
import { env } from 'cloudflare:workers';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { MfaSetup } from '@/components/auth/MfaSetup';

const redirectTo = Astro.url.searchParams.get('redirectTo') || '/superadmin/dashboard';
---

<BaseLayout title="Configurar 2FA">
  <div class="bg-background relative min-h-screen overflow-hidden">
    <div
      class="bg-accent-blue pointer-events-none absolute -top-24 -left-24 size-96 rounded-full opacity-30 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div
      class="bg-accent-pink pointer-events-none absolute -right-24 -bottom-24 size-96 rounded-full opacity-30 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div class="relative flex min-h-screen items-center justify-center p-4">
      <MfaSetup
        client:load
        supabaseUrl={env.SUPABASE_URL}
        supabaseAnonKey={env.SUPABASE_ANON_KEY}
        redirectTo={redirectTo}
      />
    </div>
  </div>
</BaseLayout>
