---
import { HugeiconsIcon } from '@hugeicons/react';
import { Link04Icon } from '@hugeicons/core-free-icons';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="No encontrado">
  <div class="bg-background relative flex min-h-screen items-center justify-center overflow-hidden p-4">
    <div
      class="bg-accent-lilac pointer-events-none absolute -top-24 -left-24 size-96 rounded-full opacity-30 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div
      class="bg-accent-pink pointer-events-none absolute -right-24 -bottom-24 size-96 rounded-full opacity-30 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div
      class="bg-card relative flex w-full max-w-sm flex-col items-center gap-3 rounded-2xl p-8 text-center shadow-[var(--shadow-card-lg)]"
    >
      <div class="bg-accent-lilac text-accent-lilac-foreground flex size-12 items-center justify-center rounded-2xl">
        <HugeiconsIcon icon={Link04Icon} size={22} />
      </div>
      <h1 class="font-heading text-3xl font-semibold">404</h1>
      <p class="text-muted-foreground text-sm">Este enlace no existe o fue eliminado.</p>
    </div>
  </div>
</BaseLayout>
