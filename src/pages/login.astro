---
import { env } from 'cloudflare:workers';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { LoginForm } from '@/components/auth/LoginForm';
import { ThemeToggle } from '@/components/layout/ThemeToggle';

if (Astro.locals.user) {
  return Astro.redirect('/admin/dashboard');
}

const redirectTo = Astro.url.searchParams.get('redirectTo') || '/admin/dashboard';
---

<BaseLayout title="Iniciar sesión">
  <div class="bg-background relative min-h-screen overflow-hidden">
    <div
      class="bg-accent-pink pointer-events-none absolute -top-24 -left-24 size-96 rounded-full opacity-30 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div
      class="bg-accent-blue pointer-events-none absolute -right-24 -bottom-24 size-96 rounded-full opacity-30 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div class="absolute top-4 right-4">
      <ThemeToggle client:load />
    </div>
    <div class="relative flex min-h-screen items-center justify-center p-4">
      <LoginForm
        client:load
        supabaseUrl={env.SUPABASE_URL}
        supabaseAnonKey={env.SUPABASE_ANON_KEY}
        redirectTo={redirectTo}
        turnstileSiteKey={env.PUBLIC_TURNSTILE_SITE_KEY}
      />
    </div>
  </div>
</BaseLayout>
