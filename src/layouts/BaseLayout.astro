---
import '../styles/global.css';
import { DEFAULT_BRANDING } from '@/lib/branding';
import { buildThemeStyle } from '@/lib/theme';

interface Props {
  title: string;
  siteName?: string;
  faviconUrl?: string | null;
  primaryColor?: string | null;
  accentColor?: string | null;
  accentYellowColor?: string | null;
  accentPinkColor?: string | null;
  accentGreenColor?: string | null;
  accentBlueColor?: string | null;
  accentLilacColor?: string | null;
  radiusRem?: number | null;
  sidebarStyle?: 'dark' | 'brand' | null;
}

const {
  title,
  siteName = DEFAULT_BRANDING.name,
  faviconUrl = DEFAULT_BRANDING.faviconUrl,
  primaryColor,
  accentColor,
  accentYellowColor,
  accentPinkColor,
  accentGreenColor,
  accentBlueColor,
  accentLilacColor,
  radiusRem,
  sidebarStyle,
} = Astro.props;

const themeCss = buildThemeStyle({
  primaryColor,
  accentColor,
  accentOverrides: {
    yellow: accentYellowColor,
    pink: accentPinkColor,
    green: accentGreenColor,
    blue: accentBlueColor,
    lilac: accentLilacColor,
  },
  radiusRem,
  sidebarStyle,
});
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {faviconUrl && <link rel="icon" href={faviconUrl} />}
    <title>{title} · {siteName}</title>
    <script is:inline>
      // Runs before paint to avoid a flash of the wrong theme. Kept out of the
      // bundled/deferred script pipeline (is:inline) precisely so it blocks
      // rendering until the class is set.
      (function () {
        const stored = localStorage.getItem('theme');
        const isDark = stored ? stored === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.classList.toggle('dark', isDark);
      })();
    </script>
    {themeCss && <style set:html={themeCss} />}
  </head>
  <body>
    <slot />
  </body>
</html>
