---
import '../styles/global.css';
import { siteConfig } from '@/lib/config';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={siteConfig.faviconUrl} />
    <title>{title} · {siteConfig.name}</title>
    <script is:inline>
      // Runs before paint to avoid a flash of the wrong theme. Kept out of the
      // bundled/deferred script pipeline (is:inline) precisely so it blocks
      // rendering until the class is set.
      (function () {
        const stored = localStorage.getItem('theme');
        const isDark = stored ? stored === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.classList.toggle('dark', isDark);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
